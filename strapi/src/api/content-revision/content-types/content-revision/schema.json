{
  "kind": "collectionType",
  "collectionName": "content_revisions",
  "info": {
    "singularName": "content-revision",
    "pluralName": "content-revisions",
    "displayName": "Content Revision",
    "description": "Version history snapshots for pages and posts"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "resource_type": {
      "type": "enumeration",
      "enum": ["page", "post"],
      "required": true
    },
    "resource_id": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "string"
    },
    "puck_data": {
      "type": "json"
    },
    "content": {
      "type": "richtext"
    },
    "snapshot": {
      "type": "json"
    }
  }
}
