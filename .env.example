# Strapi secrets (generate unique values for production)
JWT_SECRET=change-me-jwt-secret
APP_KEYS=change-me-key-1,change-me-key-2,change-me-key-3,change-me-key-4
API_TOKEN_SALT=change-me-api-token-salt
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt

# Next.js / React
STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
VITE_STRAPI_URL=http://localhost:1337
REVALIDATION_SECRET=change-me-revalidation-secret

# Optional: Strapi API token for server-side saves (bypasses user login)
STRAPI_API_TOKEN=

# NextPress app login (Users & Permissions — NOT the Strapi /admin account)
NEXTPRESS_DEFAULT_USER_EMAIL=admin@nextpress.local
NEXTPRESS_DEFAULT_USER_PASSWORD=NextPressDev123
NEXTPRESS_DEFAULT_USER_USERNAME=nextpress

# Production only (S3 media)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=
