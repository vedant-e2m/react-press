# Service ports (avoid conflicts with other local apps)
POSTGRES_PORT=5433
STRAPI_PORT=1338
WEB_PORT=3001
REACT_PORT=5174

# Strapi CMS
JWT_SECRET=change-me-jwt-secret
APP_KEYS=change-me-key-1,change-me-key-2,change-me-key-3,change-me-key-4
API_TOKEN_SALT=change-me-api-token-salt
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt
# Local dev only (outside Docker). Docker Compose overrides CMS_URL with http://strapi:${STRAPI_PORT}
CMS_URL=http://localhost:1338
STRAPI_URL=http://localhost:1338
NEXT_PUBLIC_STRAPI_URL=http://localhost:1338
STRAPI_API_TOKEN=

# CDN for media and static assets (optional)
CDN_URL=
NEXT_PUBLIC_CDN_URL=

# Next.js / React
VITE_STRAPI_URL=http://localhost:1338
VITE_CMS_URL=http://localhost:1338
REVALIDATION_SECRET=change-me-revalidation-secret
# Strapi → Next ISR webhook base URL (Docker sets this automatically)
WEB_REVALIDATE_URL=http://localhost:3001

# Admin portal is Strapi at http://localhost:1338/admin
# Optional Users & Permissions seed user (API experiments only; off by default)
NEXTPRESS_SEED_APP_USER=false
NEXTPRESS_DEFAULT_USER_EMAIL=admin@nextpress.local
NEXTPRESS_DEFAULT_USER_PASSWORD=NextPressDev123
NEXTPRESS_DEFAULT_USER_USERNAME=nextpress

# Production only (S3 media)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=
